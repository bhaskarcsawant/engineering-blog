---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const feature = posts[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="has-scrollbar">
		<Header />
		<main>
			{feature && (
				<section class="hero feature-card">
					{feature.data.heroImage ? (
						<img class="feature-img" src={feature.data.heroImage.src} alt={feature.data.title} loading="lazy" />
					) : (
						<img class="feature-img" src="/iconx32Colored.png" alt="" loading="lazy" />
					)}
					<div class="feature-body">
						<p class="feature-date"><FormattedDate date={feature.data.pubDate} /></p>
						<h1>{feature.data.title}</h1>
						<p class="lede">{feature.data.description}</p>
						<a class="cta" href={`/blog/${feature.id}/`}>Read More</a>
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>

	<style>
		.hero {
			display: grid;
			grid-template-columns: 1.3fr 1fr;
			gap: 2.4rem;
			align-items: center;
			margin-bottom: 3rem;
			margin-top: 25px;
		}

		.feature-card {
			text-decoration: none;
		}

		.feature-img {
			width: 100%;
			height: 420px;
			object-fit: cover;
			border-radius: 10px;
		}

		.feature-body h1 {
			font-size: 3rem;
			margin: 2rem 0 0.7rem;
			line-height: 1.1;
		}

		.feature-body {
			display: flex;
			flex-direction: column;
			height: 100%;
			justify-content: center;
			gap: 0.8rem;
		}

		.feature-date {
			margin: 0;
			color: #5a6472;
			font-weight: 600;
			letter-spacing: 0.01em;
		}

		.lede {
			font-family: 'Funnel Sans', "Helvetica Neue", Helvetica, Arial, sans-serif;
			font-size: 20px;
			color: #5a6472;
			line-height: 1.65;
			margin: 0 0 1.4rem;
			margin-top: 10px;
		}

		.cta {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 0.6rem;
			width: 140px;
			border-radius: 10px;
			color: #0b0f14;
			border: 1.5px solid #0b0f14;
			font-weight: 800;
			font-size: 15px;
			text-decoration: none;
			letter-spacing: 0.01em;
			transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
			margin-top: auto;
		}

	

		.cards .card {
			text-decoration: none;
		}

		@media (max-width: 900px) {
			.hero {
				grid-template-columns: 1fr;
			}
			.feature-img {
				height: 260px;
			}
		}
	</style>
</html>
