---
const today = new Date();
---

<footer>
	<div class="shell">
		<div class="links">
			<a href="https://emitrr.com" target="_blank" rel="noreferrer">Product</a>
			<a href="https://www.linkedin.com/company/emitrr/" target="_blank" rel="noreferrer">Careers</a>
		</div>
		<span class="muted">© {today.getFullYear()} Emitrr Engineering</span>
	</div>
</footer>

<style>
	footer {
		border-top: var(--border);
		background: #f8f9fb;
	}
	.shell {
		width: min(100%, var(--max-width));
		margin: 0 auto;
		padding: 1.2rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-size: 0.95rem;
	}
	.links {
		display: inline-flex;
		gap: 1.25rem;
		font-weight: 600;
	}
	.links a {
		color: var(--ink);
	}
	.muted {
		color: var(--muted);
	}
	@media (max-width: 640px) {
		.shell {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
