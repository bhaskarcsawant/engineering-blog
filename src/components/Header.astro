---
---

<header class="site-header">
	<div class="site-shell">
		<a class="site-brand" href="/">
			<img src="/iconx32.png" alt="Emitrr" />
			<span class="wordmark">Emitrr Engineering</span>
		</a>
		<nav class="site-nav">
			<a href="https://emitrr.com" target="_blank" rel="noreferrer">Product</a>
			<a href="https://www.linkedin.com/company/emitrr/" target="_blank" rel="noreferrer">Careers</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		width: 100%;
		background: #000;
		color: #fff;
	}

	.site-shell {
		width: min(100%, var(--max-width));
		margin: 0 auto;
		padding: 0.85rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		color: inherit;
		font-weight: 700;
	}

	.site-brand img {
		height: 28px;
		width: 28px;
		display: block;
	}

	.site-nav {
		display: inline-flex;
		align-items: center;
		gap: 1.25rem;
		font-weight: 600;
	}

	.site-nav a {
		color: inherit;
		opacity: 0.9;
	}

	.site-nav a:hover {
		opacity: 1;
	}

	.wordmark {
		font-size: 1rem;
		letter-spacing: 0.01em;
		line-height: 1;
	}

	@media (max-width: 640px) {
		.wordmark {
			display: none;
		}
	}
</style>
